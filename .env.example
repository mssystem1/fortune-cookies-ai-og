# Never commit a funded private key. Use a dedicated deployer wallet.
PRIVATE_KEY=0xYOUR_64_HEX_CHARACTER_PRIVATE_KEY

# Arbitrum One (chain ID 42161)
ARBITRUM_MAINNET_RPC_URL=https://arb1.arbitrum.io/rpc
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_V2_KEY

# Fill this after deployment, or let the scripts read deployed-arbitrum.json.
ARBITRUM_COOKIE_CONTRACT=

# Optional post-deployment configuration.
ARBITRUM_MINT_PRICE=0
ARBITRUM_FUNDS_RECEIVER=
ARBITRUM_ROYALTY_RECEIVER=
ARBITRUM_ROYALTY_BPS=
